# Infisical credentials (fetches LITELLM_MASTER_KEY, LITELLM_SALT_KEY, ANTHROPIC_API_KEY at startup)
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# Postgres password for litellm-db (spend tracking, virtual keys)
POSTGRES_PASSWORD=

# FUNION_SIDECAR_TOKEN — bearer token shared with /opt/apps/funion-sidecar
# for the funion-phi3 / funion-llama-3-8b model entries.
#
# Source of truth: Infisical project=litellm-proxy env=prod path=/
# (fetched at LiteLLM startup by the entrypoint-wrapper alongside
# RUNPOD_API_KEY, ANTHROPIC_API_KEY, etc.). Set this var in .env on
# Netcup ONLY as a development override; in production deployment the
# Infisical value wins.
#
# /opt/apps/funion-sidecar/.env still reads its own copy because
# funion-sidecar's compose does NOT use the Infisical wrapper today.
# The two values must be kept in lockstep; rotation runbook:
#   NEW=$(openssl rand -hex 24)
#   # 1. push to Infisical via internal API:
#   docker exec infisical curl -s -X PATCH \
#     "http://localhost:8080/api/v3/secrets/raw/FUNION_SIDECAR_TOKEN" \
#     -H "Authorization: Bearer $TOK" -H "Content-Type: application/json" \
#     -d "$(jq -n --arg v "$NEW" '{projectSlug:"litellm-proxy",environment:"prod",secretPath:"/",secretValue:$v,type:"shared"}')"
#   # 2. update /opt/apps/funion-sidecar/.env (chmod 600)
#   # 3. recreate both containers:
#   (cd /opt/apps/funion-sidecar && docker compose up -d --force-recreate)
#   (cd /opt/apps/litellm && docker compose up -d --force-recreate)
# (Future: provision a funion-sidecar Infisical project + identity so
# the wrapper fetches there too, eliminating the dual-source.)
FUNION_SIDECAR_TOKEN=
