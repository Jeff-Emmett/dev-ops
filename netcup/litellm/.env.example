# Infisical credentials (fetches LITELLM_MASTER_KEY, LITELLM_SALT_KEY, ANTHROPIC_API_KEY at startup)
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=

# Postgres password for litellm-db (spend tracking, virtual keys)
POSTGRES_PASSWORD=

# Bearer token shared with /opt/apps/funion-sidecar for the funion-phi3
# model entry. 32+ random hex chars. Set the SAME value in both
# /opt/apps/funion-sidecar/.env and /opt/apps/litellm/.env, chmod 600 each.
# To rotate:
#   NEW=$(openssl rand -hex 24)
#   for f in /opt/apps/funion-sidecar/.env /opt/apps/litellm/.env; do
#     tmp=$(mktemp); grep -v '^FUNION_SIDECAR_TOKEN=' "$f" > "$tmp"
#     echo "FUNION_SIDECAR_TOKEN=$NEW" >> "$tmp"; mv "$tmp" "$f"; chmod 600 "$f"
#   done
#   (cd /opt/apps/funion-sidecar && docker compose up -d --force-recreate)
#   (cd /opt/apps/litellm && docker compose up -d --force-recreate)
FUNION_SIDECAR_TOKEN=
