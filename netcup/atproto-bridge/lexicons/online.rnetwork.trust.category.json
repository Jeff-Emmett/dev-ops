{
  "lexicon": 1,
  "id": "online.rnetwork.trust.category",
  "defs": {
    "main": {
      "type": "record",
      "description": "An expertise category definition for the trust system.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "description", "color", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 128
          },
          "description": {
            "type": "string",
            "maxLength": 1024
          },
          "color": {
            "type": "string",
            "maxLength": 16,
            "description": "Hex color code for UI rendering"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
