# Gitea + act_runner environment.
# Copy to .env on the server (/root/gitea/.env) and fill in values.
# The real .env is gitignored — never commit it.

# Postgres password (internal network only — not exposed publicly).
# Defaults to "gitea" if unset, matching the pre-Infisical setup.
GITEA_DB_PASSWORD=gitea

# Runner registration token. One-shot: only consulted on first boot to
# register the runner against the Gitea instance. After registration,
# credentials live in ./runner-data/.runner and this var can be unset.
# Generate a new token at: /-/admin/actions/runners on the Gitea UI.
GITEA_RUNNER_REGISTRATION_TOKEN=

# Runner display name shown in the Gitea Actions UI. Only needed during
# first-boot registration; ignored afterwards.
GITEA_RUNNER_NAME=netcup-runner-01
