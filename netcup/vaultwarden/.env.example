# Vaultwarden secrets — populated on Netcup at /opt/apps/vaultwarden/.env
# DO NOT commit a real .env to git
#
# Generate ADMIN_TOKEN values with the helper script in this dir:
#   ./generate-admin-token.sh
# Plaintext goes to ~/.secrets/private/, hash goes here.

# passwords.jeffemmett.com (LIVE)
VW_ADMIN_TOKEN=
VW_SMTP_PASSWORD=

# passwords.commons-hub.io (DEFERRED — uncomment when DNS ready)
# VW_CH_ADMIN_TOKEN=
# VW_CH_SMTP_PASSWORD=
