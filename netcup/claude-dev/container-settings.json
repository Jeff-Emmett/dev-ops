{
  "permissions": {
    "allow": [
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(command=*rm -rf /*)",
      "Bash(command=*rm -rf ~*)",
      "Bash(command=*> /dev/sda*)",
      "Bash(command=*mkfs*)",
      "Bash(command=*dd if=*of=/dev*)",
      "Bash(command=*push --force*main*)",
      "Bash(command=*push --force*master*)",
      "Bash(command=*push -f*main*)",
      "Bash(command=*push -f*master*)",
      "Bash(command=*reset --hard*origin*)",
      "Bash(command=*curl*|*sh*)",
      "Bash(command=*curl*|*bash*)",
      "Bash(command=*wget*|*sh*)",
      "Bash(command=*wget*|*bash*)",
      "Bash(command=*DROP TABLE*)",
      "Bash(command=*DROP DATABASE*)",
      "Bash(command=*TRUNCATE TABLE*)",
      "Bash(command=*shutdown -h*)",
      "Bash(command=*reboot*)",
      "Bash(command=*chmod 777*)",
      "Bash(command=*chmod -R 777*)",
      "Bash(command=*docker system prune -a*)",
      "Bash(command=*docker volume prune*)",
      "Bash(command=*docker network prune*)",
      "Bash(command=*keepassxc-cli show*)",
      "Bash(command=*keepassxc-cli export*)",
      "Bash(command=*keepassxc-cli clip*)",
      "Bash(command=*keepassxc-cli dump*)",
      "Bash(command=*keepassxc-cli attachment-export*)",
      "Read(file_path=*.kdbx*)",
      "Read(file_path=*keepass-master*)",
      "Bash(command=*cat*keepass-master*)",
      "Bash(command=*cat*.kdbx*)",
      "Bash(command=*head*keepass-master*)",
      "Bash(command=*tail*keepass-master*)",
      "Bash(command=*less*keepass-master*)",
      "Bash(command=*xxd*.kdbx*)",
      "Bash(command=*strings*.kdbx*)",
      "Grep(path=*keepass-master*)",
      "Bash(command=*secrets *)",
      "Bash(command=*infisical-ops *)"
    ],
    "ask": []
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
