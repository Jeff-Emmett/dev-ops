# funion-sidecar env vars (Netcup)
#
# The bearer token gates both POST /v1/chat/completions and GET /v1/models
# on the OpenAI-compatible HTTP endpoint. Same value MUST also be set in
# /opt/apps/litellm/.env so the LiteLLM proxy can authenticate when calling
# the funion-phi3 / funion-llama-3-8b model entries.
#
# To rotate (in lockstep with /opt/apps/litellm/.env):
#   NEW=$(openssl rand -hex 24)
#   for f in /opt/apps/funion-sidecar/.env /opt/apps/litellm/.env; do
#     tmp=$(mktemp); grep -v '^FUNION_SIDECAR_TOKEN=' "$f" > "$tmp"
#     echo "FUNION_SIDECAR_TOKEN=$NEW" >> "$tmp"; mv "$tmp" "$f"; chmod 600 "$f"
#   done
#   (cd /opt/apps/funion-sidecar && docker compose up -d --force-recreate)
#   (cd /opt/apps/litellm && docker compose up -d --force-recreate)
FUNION_SIDECAR_TOKEN=
