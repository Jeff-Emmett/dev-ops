# Block aggressive bots that ignore robots.txt
RewriteEngine On

# Applebot: hammering Special pages, edit actions, and API — burns 50% CPU
RewriteCond %{HTTP_USER_AGENT} Applebot [NC]
RewriteCond %{REQUEST_URI} (Special:|api\.php) [NC,OR]
RewriteCond %{QUERY_STRING} (action=edit|action=history|title=Special|feedrecentchanges) [NC]
RewriteRule .* - [F,L]

# LinkupBot: blocked entirely
RewriteCond %{HTTP_USER_AGENT} LinkupBot [NC]
RewriteRule .* - [F,L]

# MediaWiki short URL support
RewriteBase /

# Redirect root to Main_Page
RewriteRule ^/*$ /index.php/Main_Page [L,R=301]

# Short URL support - rewrite /Page_Name to /index.php/Page_Name
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php/ [L,QSA]
