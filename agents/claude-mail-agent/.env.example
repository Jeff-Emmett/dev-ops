# IMAP (Mailcow dovecot)
IMAP_HOST=mail.rmail.online
IMAP_PORT=993
IMAP_USER=claude@jeffemmett.com
IMAP_PASS=changeme

# Postfix sendmail (replaces SMTP — stale creds workaround)
POSTFIX_CONTAINER=mailcowdockerized-postfix-mailcow-1
MAIL_FROM=claude@jeffemmett.com

# Sender allowlist — full access to FIX/STORE/REPLY (comma-separated)
ALLOWED_SENDERS=jeffemmett@gmail.com,jeff@jeffemmett.com

# Collaborator senders — FIX/REPLY within sandboxed repo only, no Bash/infra (comma-separated)
COLLAB_SENDERS=tews.consulting@gmail.com
COLLAB_REPOS=Rory-Schemes
COLLAB_MAX_BUDGET_USD=5.00

# Guest senders — REPLY-only, read-only tools, owner CC'd (comma-separated)
GUEST_SENDERS=
OWNER_CC=jeff@jeffemmett.com

# Polling and limits
POLL_INTERVAL=300
MAX_BUDGET_USD=5.00
GUEST_MAX_BUDGET_USD=2.00
MAX_EMAILS_PER_HOUR=6
MAX_EMAIL_LENGTH=10000

# Claude container to exec into
CLAUDE_CONTAINER=claude-dev
CLAUDE_WORKDIR=/opt/apps
