# IMAP (Mailcow dovecot)
IMAP_HOST=mail.rmail.online
IMAP_PORT=993
IMAP_USER=claude@jeffemmett.com
IMAP_PASS=changeme

# Postfix sendmail (replaces SMTP — stale creds workaround)
POSTFIX_CONTAINER=mailcowdockerized-postfix-mailcow-1
MAIL_FROM=claude@jeffemmett.com

# Sender allowlist (comma-separated)
ALLOWED_SENDERS=jeffemmett@gmail.com,jeff@jeffemmett.com

# Polling and limits
POLL_INTERVAL=300
MAX_BUDGET_USD=5.00
MAX_EMAILS_PER_HOUR=6
MAX_EMAIL_LENGTH=10000

# Claude container to exec into
CLAUDE_CONTAINER=claude-dev
CLAUDE_WORKDIR=/opt/apps
