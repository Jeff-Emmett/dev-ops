# GX10 LiteLLM — environment template.  Copy to .env and fill in.
#
# Per dev-ops Infisical policy, production should fetch these at startup
# via the Infisical entrypoint-wrapper rather than storing them here.
# This template documents what the router needs.

# Gate for every /v1/* request (Authorization: Bearer <this>).
# Generate: openssl rand -hex 32
LITELLM_MASTER_KEY=

# RunPod vLLM burst tier (demoted to overflow — still wired as fallback).
RUNPOD_VLLM_BASE_URL=
RUNPOD_VLLM_BEARER=

# Cloud paid fallback tier.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
